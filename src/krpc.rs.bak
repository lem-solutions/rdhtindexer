const K : usize = 8;

// TODO Serde verursacht für unseren Anwendungsfall mehr Hindernisse als es
//      wert ist. Wir sollen lieber eine imperative (De)Serialisierung
//      implementieren.

// Dieser Code ist zu komplex und unideomatisch und sollte vereinfacht werden.

// Das noalloc_vec_rs::vec::Vec keine Serde Implementierung hat zwingt uns
// hier einige Kapriolen zu schlagen, evtl. für Upstream Unterstützung sorgen
// oder was anderes benutzen.

// Wir müssen die Handhabung von `Option`en der `bendy` Bibliothek umgehen,
// evtl. mal Upstream fragen warum Optionen so gehandhabt werden und das ggf.
// ändern.

#[derive(PartialEq, Clone)]
pub struct KontaktInfoIpv4(pub [u8;6]);
impl From<KontaktInfoIpv4> for SocketAddrV4 {
	fn from(k_info: KontaktInfoIpv4) -> Self {
		SocketAddrV4::new(
			TryInto::<[u8;4]>::try_into(&k_info.0[0..4]).unwrap().try_into().unwrap(),
			u16::from_be_bytes(k_info.0[4..6].try_into().unwrap()),
		)
	}
}

#[derive(PartialEq, Clone)]
pub struct KontaktInfoIpv6(pub [u8;18]);
impl From<KontaktInfoIpv6> for SocketAddrV6 {
	fn from(k_info: KontaktInfoIpv6) -> Self {
		SocketAddrV6::new(
			TryInto::<[u8;16]>::try_into(&k_info.0[0..16]).unwrap().try_into().unwrap(),
			u16::from_be_bytes(k_info.0[16..18].try_into().unwrap()),
			0, 0
		)
	}
}

#[derive(Serialize, Deserialize, Debug, PartialEq, Eq)]
pub enum Nachrichtenart {
	#[serde(rename = "q")]
	Anfrage,
	#[serde(rename = "r")]
	Antwort,
	#[serde(rename = "e")]
	Fehler,
}

#[derive(Serialize, Deserialize, Debug, PartialEq, Eq)]
pub enum Methode {
	#[serde(rename = "ping")]
	Ping,
	#[serde(rename = "find_node")]
	FindNode,
	#[serde(rename = "get_peers")]
	GetPeers,
	#[serde(rename = "announce_peer")]
	AnnouncePeer,
	#[serde(rename = "sample_infohashes")]
	SampleInfohashes,
	#[serde(other)]
	UnbekannteMethode,
}

#[derive(Serialize, Deserialize)]
pub struct AnfrageArgumente<'a> {
	pub id: U160, // Alle Anfragen
	
	#[serde(rename = "target")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub ziel: Option<U160>, // find_node, sample_infohashes
	
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub info_hash: Option<U160>, // get_peers, announce_peer
	
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub port: Option<u16>, // announce_peer
	
	#[serde(rename = "implied_port")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub impliziter_port: Option<bool>, // announce_peer
	
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub token: Option<&'a [u8]>, // announce_peer
	
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub want: Option<Vec<&'a [u8]>>,
}

#[derive(Serialize, Deserialize)]
pub struct AntwortArgumente<A: Addr> {
	pub id: U160, // Alle Antworten
	
	#[serde(rename = "nodes")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub knoten_ipv4: Option<KnotenListe<SocketAddrV4>>, // find_node, sample_infohashes
	
	#[serde(rename = "nodes6")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub knoten_ipv6: Option<KnotenListe<SocketAddrV6>>, // find_node, sample_infohashes
	
	// TODO Verstoß gegen BEP0032: Wir können Hybridlisten nicht verarbeiten.
	#[serde(rename = "values")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub peers: Option<MiniVec<A::Krpc, K>>, // get_peers
	
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub token: Option<Vec<u8>>, // get_peers
	
	#[serde(rename = "interval")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub bep51_inverval: Option<u16>, // sample_infohashes
	
	#[serde(rename = "num")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub bep51_ges_anz_hashes: Option<usize>, // sample_infohashes
	
	#[serde(rename = "samples")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub bep51_hashes: Option<Vec<u8>>, // sample_infohashes
}

pub const KRPC_ALLGEMEINER_FEHLER : u32 = 201;
pub const KRPC_SERVER_FEHLER : u32 = 202;
pub const KRPC_PROTOKOLL_FEHLER : u32 = 203;
pub const KRPC_UNBEKANNTE_METHODE : u32 = 204;

/*
	201 	Generic Error
	202 	Server Error
	203 	Protocol Error, such as a malformed packet, invalid arguments, or bad token
	204 	Method Unknown
*/
pub struct KrpcFehler{
	pub fehlercode: u32,
	pub fehlermeldung: Vec<u8>,
}
impl Serialize for KrpcFehler {
	fn serialize<S: Serializer>(&self, s: S) -> Result<S::Ok, S::Error> {
		let mut s_seq = s.serialize_seq(Some(2))?;
		s_seq.serialize_element(&self.fehlercode)?;
		s_seq.serialize_element(self.fehlermeldung.as_slice())?;
		s_seq.end()
	}
}
impl<'de> Deserialize<'de> for KrpcFehler {
	fn deserialize<D: Deserializer<'de>>(de: D) -> Result<Self, D::Error> {
		de.deserialize_seq(KrpcFehlerVisitor)
	}
}

struct KrpcFehlerVisitor;
impl<'de> serde::de::Visitor<'de> for KrpcFehlerVisitor {
	type Value = KrpcFehler;
	
	fn expecting(&self, formatter: &mut std::fmt::Formatter) -> std::fmt::Result {
		write!(formatter, "eine Liste mit einem Fehlercode und einer Fehlermeldung")
	}
	
	fn visit_seq<A: serde::de::SeqAccess<'de>>(self, mut seq: A) -> Result<Self::Value, A::Error> {
		
		let fehlercode = seq.next_element()?.ok_or_else(|| A::Error::custom("Fehlercode fehlt"))?;
		let fehlermeldung = seq.next_element()?.ok_or_else(|| A::Error::custom("Fehlermeldung fehlt"))?;
		
		Ok(KrpcFehler{fehlercode, fehlermeldung})
	}
}


#[derive(Serialize, Deserialize)]
pub struct KrpcNachricht<'a, A:Addr>{
	#[serde(rename = "t")]
	pub transaktionsnummer: &'a [u8],
	#[serde(rename = "y")]
	pub art: Nachrichtenart,
	
	#[serde(rename = "v")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub versionscode: Option<&'a [u8]>,
	
	#[serde(rename = "q")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub anfrage_methode: Option<Methode>,
	
	#[serde(rename = "a")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub anfrage_argumente: Option<AnfrageArgumente<'a>>,
	
	#[serde(rename = "r")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub antwort_argumente: Option<AntwortArgumente<A>>,
	
	#[serde(rename = "e")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub fehler: Option<KrpcFehler>,
	
	#[serde(rename = "ip")]
	#[serde(skip_serializing_if = "Option::is_none")]
	//#[serde(default)]
	#[serde(serialize_with = "ser_option")]
	#[serde(deserialize_with = "de_option")]
	pub externe_ip: Option<A::Krpc>, // KontaktInfoIpv4 oder KontaktInfoIpv6
}

