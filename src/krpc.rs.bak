use serde_derive::*;
use serde::*;
use serde::de::*;
use serde::ser::*;

use smol::net::{SocketAddrV4, SocketAddrV6};
use std::ops::{Deref, DerefMut};
use std::marker::PhantomData;

use crate::datentypen::*;
